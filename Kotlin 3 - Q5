fun main() {
 print ("Digite o primeiro número: ")
    val num1n= readLine()!!.toInt()
    print ("Digite o segundo número: ")
    val num2 = readLine()!!.toInt()
var soma = 0
 var contador = 0
    for (i in num1n..num2) {
            soma += i
            contador++
        }
    val media = soma.toDouble() / contador
    println("A média aritmética: $media"
    )

}

